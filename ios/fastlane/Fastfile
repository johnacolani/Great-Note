default_platform(:ios)

platform :ios do
  desc "Build a signed IPA (via match) and upload it to TestFlight"
  lane :beta do
    # On CI, create a temporary keychain so match can install certs safely.
    setup_ci if is_ci

    # App Store Connect API key (used for both signing metadata and upload).
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )

    # Pull the distribution certificate + App Store profile from the match repo.
    match(
      type: "appstore",
      readonly: is_ci,
      app_identifier: "com.johncolani.infiniteNotesPlus",
      api_key: api_key
    )

    # Archive & export a signed IPA. Flutter has already compiled the app
    # (flutter build ios --no-codesign in CI), so this re-archives with signing.
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "Runner.ipa",
      clean: false
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
